# Note: If you use this file, rename it to lavalink.ini
# Note 2: if any value has the character % you must use 2 instead of 1, example: %%

[something.host] # nome do node (pode ser qualquer nome)
host=lava.link
port=80
password=youshallnotpass
secure=false
# os 2 itens abaixo não são obrigatórios (você pode simplesmente não incluir as linhas abaixo)
region=us_central
website=https://support.something.host/en/article/lavalink-hosting-okm26z/
search=true
retry_403=false
search_providers=ytsearch scsearch

